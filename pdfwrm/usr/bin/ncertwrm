#!/usr/bin/env python3
"""Remove repeated watermark image objects from PDF files.

Targets NCERT watermark specs:
1. 2480x3508, 1 bpc
2. 1894x1894, 1 bpc
3. 1894x1894, 8 bpc (soft-mask image)

Usage:
  ncertwrm [--min-page-ratio RATIO] [--spec WxH:BPC ...]
"""

import hashlib
import subprocess
import sys
from collections import defaultdict
from pathlib import Path
from typing import Dict, Optional, Set, Tuple

try:
    import fitz  # PyMuPDF
except ImportError:
    print(
        "Error: PyMuPDF is required. Install with:\n  pip install pymupdf",
        file=sys.stderr,
    )
    sys.exit(2)


DEFAULT_TARGET_SPECS: Set[Tuple[int, int, int]] = {
    (2480, 3508, 1),
    (1894, 1894, 1),
    (1894, 1894, 8),
}


def parse_spec(value: str) -> Tuple[int, int, int]:
    """Parse a spec in the form WxH:BPC (example: 2480x3508:1)."""
    try:
        wh, bpc_s = value.split(":")
        w_s, h_s = wh.lower().split("x")
        return int(w_s), int(h_s), int(bpc_s)
    except Exception as exc:
        raise ValueError(
            f"Invalid spec '{value}'. Expected format: WxH:BPC (e.g. 2480x3508:1)."
        ) from exc


def read_stream_bytes(doc: fitz.Document, xref: int) -> Optional[bytes]:
    """Read raw stream bytes for an image xref."""
    if hasattr(doc, "xref_stream_raw"):
        try:
            data = doc.xref_stream_raw(xref)
            if data is not None:
                return data
        except Exception:
            pass
    try:
        data = doc.xref_stream(xref)
        if data is not None:
            return data
    except Exception:
        pass
    return None


def collect_watermark_xrefs(
    doc: fitz.Document,
    target_specs: Set[Tuple[int, int, int]],
    min_page_ratio: float,
) -> Set[int]:
    """Return xrefs to remove, based on repeated watermark patterns across pages."""
    if doc.page_count == 0:
        return set()

    digest_to_pages: Dict[str, Set[int]] = defaultdict(set)
    digest_to_xrefs: Dict[str, Set[int]] = defaultdict(set)
    xref_to_smask: Dict[int, Set[int]] = defaultdict(set)

    for page_index in range(doc.page_count):
        page = doc[page_index]
        for img in page.get_images(full=True):
            xref, smask, width, height, bpc = img[:5]
            spec = (width, height, bpc)
            if spec not in target_specs:
                continue

            stream = read_stream_bytes(doc, xref)
            if stream:
                digest = hashlib.sha1(stream).hexdigest()
                digest_to_pages[digest].add(page_index)
                digest_to_xrefs[digest].add(xref)

            if isinstance(smask, int) and smask > 0:
                xref_to_smask[xref].add(smask)

    threshold = min_page_ratio * doc.page_count
    xrefs_to_remove: Set[int] = set()

    for digest, pages in digest_to_pages.items():
        if len(pages) >= threshold:
            xrefs_to_remove.update(digest_to_xrefs[digest])

    for xref in list(xrefs_to_remove):
        xrefs_to_remove.update(xref_to_smask.get(xref, set()))

    return xrefs_to_remove


def remove_xrefs_from_document(doc: fitz.Document, xrefs_to_remove: Set[int]) -> int:
    """Delete matching image references from every page."""
    if not xrefs_to_remove:
        return 0
    if doc.page_count and not hasattr(doc[0], "delete_image"):
        raise RuntimeError(
            "This script requires PyMuPDF with Page.delete_image(). "
            "Upgrade PyMuPDF to a recent version."
        )

    removed_occurrences = 0
    for page_index in range(doc.page_count):
        page = doc[page_index]
        page_xrefs = {img[0] for img in page.get_images(full=True)}
        for xref in page_xrefs.intersection(xrefs_to_remove):
            page.delete_image(xref)
            removed_occurrences += 1
    return removed_occurrences


def process_pdf(
    input_pdf: Path,
    output_pdf: Path,
    target_specs: Set[Tuple[int, int, int]],
    min_page_ratio: float,
) -> Tuple[int, int]:
    """Process one PDF. Returns (candidate_xrefs, removed_occurrences)."""
    doc = fitz.open(input_pdf)
    try:
        xrefs_to_remove = collect_watermark_xrefs(
            doc,
            target_specs,
            min_page_ratio,
        )
        removed_occurrences = remove_xrefs_from_document(doc, xrefs_to_remove)

        output_pdf.parent.mkdir(parents=True, exist_ok=True)
        tmp_output = output_pdf.with_name(output_pdf.name + ".tmp")
        doc.save(tmp_output, garbage=4, clean=True, deflate=True)
    finally:
        doc.close()

    tmp_output.replace(output_pdf)
    return len(xrefs_to_remove), removed_occurrences


def main() -> int:
    import argparse

    parser = argparse.ArgumentParser(
        description="Remove NCERT watermark images from PDFs by fingerprint.",
        add_help=True,
    )
    parser.add_argument(
        "pdf_file",
        help="PDF file path (required)",
    )
    parser.add_argument(
        "--min-page-ratio",
        type=float,
        default=0.3,
        help="Require watermark on at least this fraction of pages (0.0-1.0). Default: 0.3",
    )
    parser.add_argument(
        "--spec",
        action="append",
        type=parse_spec,
        dest="specs",
        help="Watermark spec WxH:BPC (e.g. 2480x3508:1). Repeat for multiple.",
    )

    args = parser.parse_args()

    if not (0.0 <= args.min_page_ratio <= 1.0):
        parser.error("--min-page-ratio must be between 0.0 and 1.0.")

    input_pdf = Path(args.pdf_file)

    if not input_pdf.is_file() or input_pdf.suffix.lower() != ".pdf":
        print(
            f"Error: input_pdf must be an existing .pdf file: {input_pdf}",
            file=sys.stderr,
        )
        return 1

    out_dir = input_pdf.parent
    stem = input_pdf.stem
    output_pdf = out_dir / f"{stem}_ncertwrm.pdf"

    if output_pdf.exists():
        print(f"Error: Output already exists: {output_pdf}", file=sys.stderr)
        return 1

    target_specs = set(args.specs) if args.specs else DEFAULT_TARGET_SPECS

    try:
        candidate_count, removed_occurrences = process_pdf(
            input_pdf=input_pdf,
            output_pdf=output_pdf,
            target_specs=target_specs,
            min_page_ratio=args.min_page_ratio,
        )
        print(
            f"[OK] {input_pdf} -> {output_pdf} | "
            f"candidate_xrefs={candidate_count}, removed_occurrences={removed_occurrences}"
        )
        return 0
    except Exception as exc:
        print(f"[ERROR] {input_pdf}: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
