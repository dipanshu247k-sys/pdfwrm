#!/bin/bash

set -euo pipefail

BLUE="\033[34m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
RESET="\033[0m"

print_info() {
    printf "%b\n" "${BLUE}$1${RESET}"
}

print_error() {
    printf "%b\n" "${RED}$1${RESET}" >&2
}

require_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        print_error "Missing required command: $1"
        exit 1
    fi
}

require_cmd fzf

# Interactive file picker function
choose_file() {
    local current_dir=""

    if [ -d "/sdcard" ]; then
        current_dir="/sdcard"
    elif [ -d "/storage/emulated/0" ]; then
        current_dir="/storage/emulated/0"
    else
        current_dir="$PWD"
    fi

    while true; do
        local items=()
        local dir_entries=()
        local pdf_entries=()

        # Add parent directory option if not at root
        if [ "$current_dir" != "/" ]; then
            items+=(".. (parent directory)")
        fi

        if [ ! -d "$current_dir" ] || [ ! -r "$current_dir" ]; then
            print_error "Cannot read directory: $current_dir"
            exit 1
        fi

        # Collect subdirectories.
        shopt -s nullglob
        for entry in "$current_dir"/*; do
            if [ -d "$entry" ]; then
                dir_entries+=("$entry")
            fi
        done

        # Collect PDF files.
        for entry in "$current_dir"/*.pdf "$current_dir"/*.PDF; do
            if [ -f "$entry" ]; then
                pdf_entries+=("$entry")
            fi
        done
        shopt -u nullglob

        for entry in "${dir_entries[@]}"; do
            items+=("📁 $(basename "$entry")/")
        done
        for entry in "${pdf_entries[@]}"; do
            items+=("📄 $(basename "$entry")")
        done

        if [ "$current_dir" = "/" ] && [ "${#items[@]}" -gt 0 ] && [ "${items[0]}" = ".. (parent directory)" ]; then
            items=("${items[@]:1}")
        fi

        if [ ${#items[@]} -eq 0 ]; then
            print_error "No folders or PDF files in $current_dir"
            exit 1
        fi

        # Use fzf to select
        local selected
        selected=$(printf '%s\n' "${items[@]}" | fzf --header "Current: $current_dir") || {
            print_error "File selection canceled."
            exit 1
        }

        if [ -z "$selected" ]; then
            print_error "No file selected."
            exit 1
        fi

        # Handle parent directory navigation
        if [ "$selected" = ".. (parent directory)" ]; then
            current_dir=$(dirname "$current_dir")
            continue
        fi

        # Remove emoji prefix
        local selected_name="${selected#📁 }"
        selected_name="${selected_name#📄 }"
        selected_name="${selected_name%/}"

        local selected_path="$current_dir/$selected_name"

        # If directory, navigate into it
        if [[ "$selected" == 📁* ]]; then
            current_dir="$selected_path"
            continue
        fi

        # If PDF file, return it
        if [[ "$selected" == 📄* ]]; then
            echo "$selected_path"
            return 0
        fi
    done
}

# Choose tool first
CHOICE=$(printf "ncertwrm\nimagebased" | fzf --height 10 --border --header "Choose tool to run:" --preview "echo 'Processing PDF files'")

if [ -z "$CHOICE" ]; then
    print_error "No option selected."
    exit 1
fi

# Get file path
PDF_FILE=$(choose_file)

case "$CHOICE" in
    ncertwrm)
        exec ncertwrm "$PDF_FILE"
        ;;
    imagebased)
        exec imagebased "$PDF_FILE"
        ;;
    *)
        print_error "Unknown option: $CHOICE"
        exit 1
        ;;
esac
